<Window x:Class="WPFHotel.Reportes"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="Reportes — Hotel Management"
        WindowStyle="None" ResizeMode="NoResize"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#1C1C1E">

    <Window.Resources>

        <Style x:Key="TabBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#9CA3AF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="20,0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabBtnActive" TargetType="Button" BasedOn="{StaticResource TabBtn}">
            <Setter Property="Foreground" Value="#60A5FA"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border Background="Transparent"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"
                                                  HorizontalAlignment="Center"/>
                            </Border>
                            <Border Height="2" VerticalAlignment="Bottom"
                                    Background="#60A5FA"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnFiltro" TargetType="Button">
            <Setter Property="Background"      Value="#2D2D3F"/>
            <Setter Property="Foreground"      Value="#E5E7EB"/>
            <Setter Property="BorderBrush"     Value="#4B5563"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="14,7"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#374151"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnFiltroActivo" TargetType="Button" BasedOn="{StaticResource BtnFiltro}">
            <Setter Property="Background"  Value="#2563A8"/>
            <Setter Property="BorderBrush" Value="#2563A8"/>
            <Setter Property="Foreground"  Value="White"/>
        </Style>

        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BtnFiltro}">
            <Setter Property="Background"  Value="#FEE2E2"/>
            <Setter Property="Foreground"  Value="#B91C1C"/>
            <Setter Property="BorderBrush" Value="#FCA5A5"/>
        </Style>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background"      Value="#2A2A3E"/>
            <Setter Property="BorderBrush"     Value="#3B3B50"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="10"/>
            <Setter Property="Padding"         Value="18,14"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="48"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#2563A8">
            <Grid Margin="16,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox Width="22" Height="22" Margin="0,0,10,0">
                        <Canvas Width="24" Height="24">
                            <Polygon Points="12,2 22,10 22,22 2,22 2,10"
                                     Stroke="White" StrokeThickness="1.8"
                                     Fill="Transparent"/>
                            <Rectangle Canvas.Left="9" Canvas.Top="14"
                                       Width="6" Height="8" Fill="White"/>
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="Hotel Management — Reportes"
                               FontSize="17" FontWeight="Bold"
                               FontFamily="Segoe UI" Foreground="White"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="← Volver" Style="{StaticResource BtnDanger}"
                            Click="BtnVolver_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- TABS -->
        <Border Grid.Row="1" Background="#252535">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Stretch">
                <Button x:Name="TabIngresos"
                        Content="Ingresos por período"
                        Style="{StaticResource TabBtnActive}"
                        Click="TabIngresos_Click"/>
                <Button x:Name="TabHabitaciones"
                        Content="Habitaciones más ocupadas"
                        Style="{StaticResource TabBtn}"
                        Click="TabHabitaciones_Click"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="#3B3B50"/>

        <!-- CONTENIDO -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto"
                      Background="#1C1C1E">
            <StackPanel Margin="24,20,24,24">

                <!-- ════════════════════════════════ -->
                <!--  PANEL INGRESOS                  -->
                <!-- ════════════════════════════════ -->
                <StackPanel x:Name="PanelIngresos">

                    <!-- Filtros período -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <TextBlock Text="Período:" FontFamily="Segoe UI" FontSize="14"
                                   Foreground="#D1D5DB" VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>
                        <Button x:Name="BtnDiario"  Content="Diario"
                                Style="{StaticResource BtnFiltroActivo}"
                                Margin="0,0,8,0" Click="BtnPeriodo_Click" Tag="Diario"/>
                        <Button x:Name="BtnSemanal" Content="Semanal"
                                Style="{StaticResource BtnFiltro}"
                                Margin="0,0,8,0" Click="BtnPeriodo_Click" Tag="Semanal"/>
                        <Button x:Name="BtnMensual" Content="Mensual"
                                Style="{StaticResource BtnFiltro}"
                                Click="BtnPeriodo_Click" Tag="Mensual"/>
                    </StackPanel>

                    <!-- Tarjetas resumen -->
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="Total ingresos" FontFamily="Segoe UI"
                                           FontSize="12" Foreground="#9CA3AF" Margin="0,0,0,6"/>
                                <TextBlock x:Name="TxtTotalIngresos" Text="$0.00"
                                           FontFamily="Segoe UI" FontSize="26"
                                           FontWeight="Bold" Foreground="#4ADE80"/>
                                <TextBlock x:Name="TxtPeriodoLabel" Text="Hoy"
                                           FontFamily="Segoe UI" FontSize="11"
                                           Foreground="#6B7280" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="Reservaciones" FontFamily="Segoe UI"
                                           FontSize="12" Foreground="#9CA3AF" Margin="0,0,0,6"/>
                                <TextBlock x:Name="TxtTotalReservas" Text="0"
                                           FontFamily="Segoe UI" FontSize="26"
                                           FontWeight="Bold" Foreground="#60A5FA"/>
                                <TextBlock x:Name="TxtReservasPeriodo" Text="Hoy"
                                           FontFamily="Segoe UI" FontSize="11"
                                           Foreground="#6B7280" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="4" Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="Promedio por reserva" FontFamily="Segoe UI"
                                           FontSize="12" Foreground="#9CA3AF" Margin="0,0,0,6"/>
                                <TextBlock x:Name="TxtPromedio" Text="$0.00"
                                           FontFamily="Segoe UI" FontSize="26"
                                           FontWeight="Bold" Foreground="#FBBF24"/>
                                <TextBlock Text="Por huésped" FontFamily="Segoe UI"
                                           FontSize="11" Foreground="#6B7280" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Gráfica ingresos -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="Ingresos por tipo de habitación"
                                           FontFamily="Segoe UI" FontSize="13"
                                           FontWeight="SemiBold" Foreground="White"
                                           Margin="0,0,0,12"/>
                                <lvc:PieChart x:Name="GraficaIngresos"
                                              Height="280"
                                              LegendPosition="Bottom"
                                              Background="Transparent"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="Ingresos por estatus de huésped"
                                           FontFamily="Segoe UI" FontSize="13"
                                           FontWeight="SemiBold" Foreground="White"
                                           Margin="0,0,0,12"/>
                                <lvc:PieChart x:Name="GraficaEstatusIngresos"
                                              Height="280"
                                              LegendPosition="Bottom"
                                              Background="Transparent"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                </StackPanel>

                <!-- ════════════════════════════════ -->
                <!--  PANEL HABITACIONES              -->
                <!-- ════════════════════════════════ -->
                <StackPanel x:Name="PanelHabitaciones" Visibility="Collapsed">

                    <!-- Tarjetas -->
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="Hab. más ocupada" FontFamily="Segoe UI"
                                           FontSize="12" Foreground="#9CA3AF" Margin="0,0,0,6"/>
                                <TextBlock x:Name="TxtHabMasOcupada" Text="—"
                                           FontFamily="Segoe UI" FontSize="26"
                                           FontWeight="Bold" Foreground="#60A5FA"/>
                                <TextBlock x:Name="TxtHabVeces" Text="0 veces"
                                           FontFamily="Segoe UI" FontSize="11"
                                           Foreground="#6B7280" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="Total ocupaciones" FontFamily="Segoe UI"
                                           FontSize="12" Foreground="#9CA3AF" Margin="0,0,0,6"/>
                                <TextBlock x:Name="TxtTotalOcupaciones" Text="0"
                                           FontFamily="Segoe UI" FontSize="26"
                                           FontWeight="Bold" Foreground="#4ADE80"/>
                                <TextBlock Text="Registros históricos" FontFamily="Segoe UI"
                                           FontSize="11" Foreground="#6B7280" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="4" Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="Ingresos top hab." FontFamily="Segoe UI"
                                           FontSize="12" Foreground="#9CA3AF" Margin="0,0,0,6"/>
                                <TextBlock x:Name="TxtIngresosTopHab" Text="$0.00"
                                           FontFamily="Segoe UI" FontSize="26"
                                           FontWeight="Bold" Foreground="#FBBF24"/>
                                <TextBlock Text="Habitación líder" FontFamily="Segoe UI"
                                           FontSize="11" Foreground="#6B7280" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Gráfica habitaciones -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="Ocupaciones por habitación (histórico)"
                                       FontFamily="Segoe UI" FontSize="13"
                                       FontWeight="SemiBold" Foreground="White"
                                       Margin="0,0,0,12"/>
                            <lvc:PieChart x:Name="GraficaHabitaciones"
                                          Height="340"
                                          LegendPosition="Right"
                                          Background="Transparent"/>
                        </StackPanel>
                    </Border>

                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
