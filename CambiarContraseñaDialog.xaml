<Window x:Class="WPFHotel.CambiarContraseñaDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cambiar contraseña"
        Height="600" Width="420"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetName="Card"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.35"/>
            <DoubleAnimation Storyboard.TargetName="Card"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="14" To="0" Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- ── Estilo TextBlock label ── -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="Margin"     Value="0,0,0,5"/>
        </Style>


        <!-- ── Estilo TextBox (para usuario) ── -->
        <Style x:Key="ModernTxb" TargetType="TextBox">
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Foreground"      Value="#F0F0F0"/>
            <Setter Property="CaretBrush"      Value="#F0F0F0"/>
            <Setter Property="Background"      Value="#3A3A3C"/>
            <Setter Property="BorderBrush"     Value="#555558"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="Margin"          Value="0,0,0,14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="12,0"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#2563A8"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#7A7A7E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!-- ── Estilo PasswordBox ── -->
        <Style x:Key="ModernPwb" TargetType="PasswordBox">
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Foreground"      Value="#F0F0F0"/>
            <Setter Property="CaretBrush"      Value="#F0F0F0"/>
            <Setter Property="Background"      Value="#3A3A3C"/>
            <Setter Property="BorderBrush"     Value="#555558"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="Margin"          Value="0,0,0,14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="12,0"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="#F0F0F0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#2563A8"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#7A7A7E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border x:Name="Card"
            Background="#1E1E2E"
            CornerRadius="16"
            BorderBrush="#2563A8"
            BorderThickness="1"
            Opacity="0">
        <Border.RenderTransform>
            <TranslateTransform Y="14"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="40"
                              ShadowDepth="0" Opacity="0.7"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Header  -->
                <RowDefinition Height="*"/>
                <!-- Cuerpo  -->
                <RowDefinition Height="Auto"/>
                <!-- Footer  -->
            </Grid.RowDefinitions>

            <!-- ── Header ── -->
            <Border Grid.Row="0" Background="#2563A8"
                    CornerRadius="15,15,0,0" Padding="24,18">
                <StackPanel HorizontalAlignment="Center">
                    <Border Width="60" Height="60" CornerRadius="30"
                            Background="#1A3A6A"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,12">
                        <Border.Effect>
                            <DropShadowEffect Color="#60A5FA" BlurRadius="14"
                                              ShadowDepth="0" Opacity="0.5"/>
                        </Border.Effect>
                        <!-- Ícono candado -->
                        <!-- Ícono candado — CORREGIDO -->
                        <Viewbox Width="28" Height="28">
                            <Canvas Width="24" Height="24">
                                <!-- Cuerpo del candado -->
                                <Rectangle Canvas.Left="3" Canvas.Top="11"
                   Width="18" Height="11"
                   RadiusX="2" RadiusY="2"
                   Fill="#60A5FA"/>
                                <!-- Arco superior -->
                                <Path Data="M7,11 V7 A5,5 0 0,1 17,7 V11"
              Stroke="#60A5FA" StrokeThickness="2"
              Fill="Transparent"/>
                                <!-- Punto central -->
                                <Ellipse Canvas.Left="10" Canvas.Top="14"
                 Width="4" Height="4"
                 Fill="#1A3A6A"/>
                            </Canvas>
                        </Viewbox>
                    </Border>
                    <TextBlock Text="Cambiar contraseña"
                               FontFamily="Segoe UI" FontSize="18"
                               FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Actualiza las credenciales de acceso"
                               FontFamily="Segoe UI" FontSize="12"
                               Foreground="#93C5FD"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- ── Cuerpo ── -->
            <StackPanel Grid.Row="1" Margin="28,22,28,8">

                <!-- Usuario -->
                <TextBlock Text="Nombre de usuario" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtUsuario"
                         Style="{StaticResource ModernTxb}"/>

                <!-- Contraseña actual -->
                <TextBlock Text="Contraseña actual" Style="{StaticResource FieldLabel}"/>
                <PasswordBox x:Name="PwbActual"
                             Style="{StaticResource ModernPwb}"/>

                <!-- Nueva contraseña -->
                <TextBlock Text="Nueva contraseña" Style="{StaticResource FieldLabel}"/>
                <PasswordBox x:Name="PwbNueva"
                             Style="{StaticResource ModernPwb}"/>

                <!-- Confirmar nueva -->
                <TextBlock Text="Confirmar nueva contraseña"
                           Style="{StaticResource FieldLabel}"/>
                <PasswordBox x:Name="PwbConfirmar"
                             Style="{StaticResource ModernPwb}"
                             Margin="0"/>

                <!-- Mensaje de error / éxito -->
                <TextBlock x:Name="TxtMensaje"
                           FontFamily="Segoe UI" FontSize="12"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"
                           Visibility="Collapsed"/>

            </StackPanel>

            <!-- ── Footer ── -->
            <Border Grid.Row="2"
                    BorderBrush="#2A2A3E" BorderThickness="0,1,0,0"
                    Padding="24,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Cancelar -->
                    <Button Grid.Column="0" Content="Cancelar"
                            Click="BtnCancelar_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="#2D2D3F"
                                        CornerRadius="8" Padding="0,10">
                                    <TextBlock Text="{TemplateBinding Content}"
                                               FontFamily="Segoe UI" FontSize="13"
                                               Foreground="#9CA3AF"
                                               HorizontalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background"
                                                Value="#374151"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Guardar -->
                    <Button Grid.Column="2" Content="Guardar cambios"
                            Click="BtnGuardar_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="#2563A8"
                                        CornerRadius="8" Padding="0,10">
                                    <TextBlock Text="{TemplateBinding Content}"
                                               FontFamily="Segoe UI" FontSize="13"
                                               FontWeight="SemiBold" Foreground="White"
                                               HorizontalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background"
                                                Value="#1D4ED8"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="bg" Property="Background"
                                                Value="#1E40AF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
