<Window x:Class="WPFHotel.Gestion"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:WPFHotel"
      mc:Ignorable="d"
      Title="Gestión — Hotel Management"
      WindowStyle="None" ResizeMode="NoResize"
      WindowState="Maximized"
      WindowStartupLocation="CenterScreen"
      Background="#1C1C1E">

    <Window.Resources>

        <Style x:Key="TabBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#9CA3AF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="20,0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabBtnActive" TargetType="Button" BasedOn="{StaticResource TabBtn}">
            <Setter Property="Foreground" Value="#60A5FA"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border Background="Transparent"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"
                                                  HorizontalAlignment="Center"/>
                            </Border>
                            <Border Height="2" VerticalAlignment="Bottom"
                                    Background="#60A5FA"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnDanger" TargetType="Button">
            <Setter Property="Background"      Value="#FEE2E2"/>
            <Setter Property="Foreground"      Value="#B91C1C"/>
            <Setter Property="BorderBrush"     Value="#FCA5A5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="14,7"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FECACA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ColHeader" TargetType="TextBlock">
            <Setter Property="FontFamily"        Value="Segoe UI"/>
            <Setter Property="FontSize"          Value="11"/>
            <Setter Property="FontWeight"        Value="SemiBold"/>
            <Setter Property="Foreground"        Value="#6B7280"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <!-- Header    -->
            <RowDefinition Height="48"/>
            <!-- Sub-tabs  -->
            <RowDefinition Height="1"/>
            <!-- Separador -->
            <RowDefinition Height="*"/>
            <!-- Contenido -->
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#2563A8">
            <Grid Margin="16,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox Width="22" Height="22" Margin="0,0,10,0">
                        <Canvas Width="24" Height="24">
                            <Polygon Points="12,2 22,10 22,22 2,22 2,10"
                                     Stroke="White" StrokeThickness="1.8"
                                     Fill="Transparent"/>
                            <Rectangle Canvas.Left="9" Canvas.Top="14"
                                       Width="6" Height="8" Fill="White"/>
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="Hotel Management — Gestión"
                               FontSize="17" FontWeight="Bold"
                               FontFamily="Segoe UI" Foreground="White"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="← Volver al inicio"
                            Style="{StaticResource BtnDanger}"
                            Click="BtnVolver_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- SUB-TABS -->
        <Border Grid.Row="1" Background="#252535">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Stretch">
                <Button x:Name="TabHistorial"
                        Content="Historial de huéspedes"
                        Style="{StaticResource TabBtnActive}"
                        Click="TabHistorial_Click"/>
                <Button x:Name="TabHabitaciones"
                        Content="Habitaciones"
                        Style="{StaticResource TabBtn}"
                        Click="TabHabitaciones_Click"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="#3B3B50"/>

        <!-- CONTENIDO -->
        <Grid Grid.Row="3" Background="#1C1C1E">

            <!-- ══════════════════════════════════════ -->
            <!--  PANEL HISTORIAL                       -->
            <!-- ══════════════════════════════════════ -->
            <Grid x:Name="PanelHistorial" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Título        -->
                    <RowDefinition Height="Auto"/>
                    <!-- Encab columnas-->
                    <RowDefinition Height="*"/>
                    <!-- Filas datos   -->
                </Grid.RowDefinitions>

                <!-- Fila 0: Título -->
                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="Historial de huéspedes"
                               FontFamily="Segoe UI" FontSize="17"
                               FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="Todos los huéspedes que han pasado por el hotel"
                               FontFamily="Segoe UI" FontSize="12"
                               Foreground="#6B7280" Margin="0,3,0,0"/>
                </StackPanel>

                <!-- Fila 1: Encabezado columnas -->
                <Border Grid.Row="1"
                        Background="#252527" CornerRadius="8,8,0,0"
                        BorderBrush="#3A3A3C" BorderThickness="1,1,1,0"
                        Padding="16,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="#"            Style="{StaticResource ColHeader}"/>
                        <TextBlock Grid.Column="1" Text="NOMBRE"       Style="{StaticResource ColHeader}"/>
                        <TextBlock Grid.Column="2" Text="HABITACIÓN"   Style="{StaticResource ColHeader}"/>
                        <TextBlock Grid.Column="3" Text="ESTATUS"      Style="{StaticResource ColHeader}"/>
                        <TextBlock Grid.Column="4" Text="FECHA SALIDA" Style="{StaticResource ColHeader}"/>
                        <TextBlock Grid.Column="5" Text="COSTO"        Style="{StaticResource ColHeader}"/>
                        <TextBlock Grid.Column="6" Text="TIPO"         Style="{StaticResource ColHeader}"/>
                    </Grid>
                </Border>

                <!-- Fila 2: Datos con scroll -->
                <Border Grid.Row="2"
                        Background="#2A2A2C" CornerRadius="0,0,8,8"
                        BorderBrush="#3A3A3C" BorderThickness="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ListaHistorial">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#333335"
                                            BorderThickness="0,0,0,1"
                                            Padding="16,11">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#252540"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="44"/>
                                                <ColumnDefinition Width="1*"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="80"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Id}"
                                                       Foreground="#6B7280" FontSize="13"
                                                       FontFamily="Segoe UI"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding NombreCompleto}"
                                                       Foreground="#F0F0F0" FontSize="13"
                                                       FontFamily="Segoe UI"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Habitacion}"
                                                       Foreground="#9CA3AF" FontSize="12"
                                                       FontFamily="Segoe UI"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding Estatus}"
                                                       Foreground="#9CA3AF" FontSize="12"
                                                       FontFamily="Segoe UI"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="4"
                                                       Text="{Binding FechaSalidaStr}"
                                                       Foreground="#9CA3AF" FontSize="12"
                                                       FontFamily="Segoe UI"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="5"
                                                       Text="{Binding CostoStr}"
                                                       Foreground="#4ADE80" FontSize="13"
                                                       FontFamily="Segoe UI"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="6"
                                                       Text="{Binding Tipo}"
                                                       Foreground="#9CA3AF" FontSize="12"
                                                       FontFamily="Segoe UI"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

            </Grid>

            <!-- ══════════════════════════════════════ -->
            <!--  PANEL HABITACIONES                    -->
            <!-- ══════════════════════════════════════ -->
            <Grid x:Name="PanelHabitaciones" Margin="20" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Título        -->
                    <RowDefinition Height="Auto"/>
                    <!-- Encab columnas-->
                    <RowDefinition Height="*"/>
                    <!-- Filas datos   -->
                </Grid.RowDefinitions>

                <!-- Fila 0: Título -->
                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="Habitaciones registradas"
                               FontFamily="Segoe UI" FontSize="17"
                               FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="Lista de todas las habitaciones del hotel"
                               FontFamily="Segoe UI" FontSize="12"
                               Foreground="#6B7280" Margin="0,3,0,0"/>
                </StackPanel>

                <!-- Fila 1: Encabezado columnas -->
                <Border Grid.Row="1"
                        Background="#252527" CornerRadius="8,8,0,0"
                        BorderBrush="#3A3A3C" BorderThickness="1,1,1,0"
                        Padding="16,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="#"          Style="{StaticResource ColHeader}"/>
                        <TextBlock Grid.Column="1" Text="NÚMERO"     Style="{StaticResource ColHeader}"/>
                        <TextBlock Grid.Column="2" Text="TIPO"       Style="{StaticResource ColHeader}"/>
                        <TextBlock Grid.Column="3" Text="DISPONIBLE" Style="{StaticResource ColHeader}"/>
                    </Grid>
                </Border>

                <!-- Fila 2: Datos con scroll -->
                <Border Grid.Row="2"
                        Background="#2A2A2C" CornerRadius="0,0,8,8"
                        BorderBrush="#3A3A3C" BorderThickness="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ListaHabitacionesGestion">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#333335"
                                            BorderThickness="0,0,0,1"
                                            Padding="16,11">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#252540"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Numero}"
                                                       Foreground="#6B7280" FontSize="13"
                                                       FontFamily="Segoe UI"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Numero}"
                                                       Foreground="#F0F0F0" FontSize="13"
                                                       FontFamily="Segoe UI"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Tipo}"
                                                       Foreground="#9CA3AF" FontSize="12"
                                                       FontFamily="Segoe UI"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding Disponible}"
                                                       FontSize="12" FontFamily="Segoe UI"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#4ADE80"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Disponible}"
                                                                         Value="✘ Ocupada">
                                                                <Setter Property="Foreground" Value="#F87171"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

            </Grid>

            <!-- Panel reservaciones oculto (mantenido para no romper code-behind) -->
            <Grid x:Name="PanelReservaciones" Visibility="Collapsed">
                <ItemsControl x:Name="ListaReservacionesGestion"/>
            </Grid>

        </Grid>
    </Grid>
</Window>
