<Window x:Class="WPFHotel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Height="500" Width="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#1C1C1E">

    <Window.Resources>

        <!-- ══ TextBox con placeholder funcional ══ -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="FontFamily"               Value="Segoe UI"/>
            <Setter Property="FontSize"                 Value="14"/>
            <Setter Property="Foreground"               Value="#F0F0F0"/>
            <Setter Property="CaretBrush"               Value="#F0F0F0"/>
            <Setter Property="SelectionBrush"           Value="#2563A8"/>
            <Setter Property="Background"               Value="#3A3A3C"/>
            <Setter Property="BorderBrush"              Value="#555558"/>
            <Setter Property="BorderThickness"          Value="1.5"/>
            <Setter Property="Height"                   Value="44"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Grid>
                                <!-- Placeholder: visible solo cuando Text está vacío Y no tiene foco -->
                                <TextBlock x:Name="placeholder"
                                           Text="{TemplateBinding Tag}"
                                           Foreground="#6B7280"
                                           FontSize="14"
                                           FontFamily="Segoe UI"
                                           VerticalAlignment="Center"
                                           Margin="14,0,0,0"
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed"/>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="12,0"
                                              VerticalAlignment="Center"
                                              Foreground="#F0F0F0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Muestra placeholder solo si Text vacío Y sin foco -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Text"      Value=""/>
                                    <Condition Property="IsFocused" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="placeholder" Property="Visibility" Value="Visible"/>
                            </MultiTrigger>
                            <!-- Borde azul al enfocar -->
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#2563A8"/>
                            </Trigger>
                            <!-- Borde más claro al pasar el mouse -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#7A7A7E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ PasswordBox ══ -->
        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="FontFamily"               Value="Segoe UI"/>
            <Setter Property="FontSize"                 Value="14"/>
            <Setter Property="Foreground"               Value="#F0F0F0"/>
            <Setter Property="CaretBrush"               Value="#F0F0F0"/>
            <Setter Property="SelectionBrush"           Value="#2563A8"/>
            <Setter Property="Background"               Value="#3A3A3C"/>
            <Setter Property="BorderBrush"              Value="#555558"/>
            <Setter Property="BorderThickness"          Value="1.5"/>
            <Setter Property="Height"                   Value="44"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="12,0"
                                          VerticalAlignment="Center"
                                          Foreground="#F0F0F0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#2563A8"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#7A7A7E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ Label de campo ══ -->
        <Style x:Key="FieldLabel" TargetType="Label">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Foreground" Value="#D1D5DB"/>
            <Setter Property="Background" Value="{x:Null}"/>
            <Setter Property="Padding"    Value="2,0,0,4"/>
        </Style>

        <!-- ══ Botón principal ══ -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Background"      Value="#2563A8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="46"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="#1E40AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Background="#1C1C1E">

        <!-- Tarjeta central -->
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="370"
                Background="#2A2A2C"
                BorderBrush="#3A3A3C"
                BorderThickness="1"
                CornerRadius="18"
                Padding="36,32">

            <StackPanel>

                <!-- Ícono circular -->
                <Border Width="64" Height="64"
                        CornerRadius="32"
                        Background="#1A3A6A"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,18">
                    <Viewbox Width="32" Height="32">
                        <Canvas Width="24" Height="24">
                            <Polygon Points="12,3 21,10.5 21,21 3,21 3,10.5"
                                     Stroke="#60A5FA" StrokeThickness="1.5"
                                     Fill="Transparent"/>
                            <Rectangle Canvas.Left="9" Canvas.Top="14"
                                       Width="6" Height="7"
                                       Fill="#60A5FA"/>
                        </Canvas>
                    </Viewbox>
                </Border>

                <!-- Título -->
                <TextBlock Text="Bienvenido"
                           FontFamily="Segoe UI"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>

                <!-- Subtítulo -->
                <TextBlock Text="Ingresa tus credenciales para continuar"
                           FontFamily="Segoe UI"
                           FontSize="13"
                           Foreground="#9CA3AF"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,28"/>

                <!-- Usuario -->
                <Label Content="Usuario" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="txtUser"
                         Tag="Nombre de usuario"
                         Style="{StaticResource ModernTextBox}"
                         Margin="0,0,0,14"/>

                <!-- Contraseña -->
                <Label Content="Contraseña" Style="{StaticResource FieldLabel}"/>
                <PasswordBox x:Name="txtPassword"
                             Style="{StaticResource ModernPasswordBox}"
                             Margin="0,0,0,24"/>

                <!-- Botón -->
                <Button x:Name="btnRegistrar"
                        Content="Iniciar sesión"
                        Style="{StaticResource PrimaryButton}"
                        Click="btnRegistrar_Click"/>

            </StackPanel>
        </Border>

    </Grid>
</Window>
