<Window x:Class="WPFHotel.RegistrarUsuarioDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Registrar Usuario"
        Height="495" Width="420"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="NoResize"
        Background="#1C1C1E">

    <Window.Resources>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="Margin"     Value="0,0,0,5"/>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Foreground"      Value="#F0F0F0"/>
            <Setter Property="CaretBrush"      Value="#F0F0F0"/>
            <Setter Property="Background"      Value="#3A3A3C"/>
            <Setter Property="BorderBrush"     Value="#555558"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="Margin"          Value="0,0,0,14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="10,0"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="#F0F0F0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#2563A8"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#7A7A7E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Foreground"      Value="#F0F0F0"/>
            <Setter Property="CaretBrush"      Value="#F0F0F0"/>
            <Setter Property="Background"      Value="#3A3A3C"/>
            <Setter Property="BorderBrush"     Value="#555558"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="Margin"          Value="0,0,0,14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="10,0"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="#F0F0F0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#2563A8"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#7A7A7E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Foreground"      Value="Black"/>
            <Setter Property="Background"      Value="#3A3A3C"/>
            <Setter Property="BorderBrush"     Value="#555558"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="Margin"          Value="0,0,0,14"/>
            <Setter Property="Padding"         Value="8,0"/>
        </Style>

    </Window.Resources>

    <Border Background="#2A2A2C" CornerRadius="14"
            BorderBrush="#3A3A3C" BorderThickness="1"
            Margin="10" Padding="28,24">
        <StackPanel>

            <!-- Título -->
            <TextBlock Text="Registrar Usuario"
                       FontFamily="Segoe UI" FontSize="18"
                       FontWeight="SemiBold" Foreground="White"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Completa los datos del nuevo usuario"
                       FontFamily="Segoe UI" FontSize="13"
                       Foreground="#9CA3AF" Margin="0,0,0,20"/>

            <!-- Nombre -->
            <TextBlock Text="Nombre completo" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="TxtNombre" Style="{StaticResource ModernTextBox}"/>

            <!-- Usuario -->
            <TextBlock Text="Nombre de usuario" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="TxtUsuario" Style="{StaticResource ModernTextBox}"/>

            <!-- Contraseña y Confirmar en fila -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Contraseña" Style="{StaticResource FieldLabel}"/>
                    <PasswordBox x:Name="PwbPassword"
                                 Style="{StaticResource ModernPasswordBox}"
                                 Margin="0"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Confirmar" Style="{StaticResource FieldLabel}"/>
                    <PasswordBox x:Name="PwbConfirmar"
                                 Style="{StaticResource ModernPasswordBox}"
                                 Margin="0"/>
                </StackPanel>
            </Grid>

            <!-- Rol -->
            <TextBlock Text="Rol" Style="{StaticResource FieldLabel}"/>
            <ComboBox x:Name="CbbRol"
                      Style="{StaticResource ModernComboBox}"
                      SelectedIndex="0">
                <ComboBoxItem Content="normal"/>
                <ComboBoxItem Content="admin"/>
            </ComboBox>

            <!-- Botones -->
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Cancelar"
                        Click="BtnCancelar_Click"
                        Height="42" FontSize="14" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#3A3A3C" CornerRadius="9">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Foreground>
                        <SolidColorBrush Color="#9CA3AF"/>
                    </Button.Foreground>
                </Button>

                <Button Grid.Column="2" Content="Registrar"
                        Click="BtnRegistrar_Click"
                        Height="42" FontSize="14"
                        FontWeight="SemiBold" Cursor="Hand"
                        Foreground="White">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="#2563A8" CornerRadius="9">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#1D4ED8"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#1E40AF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </Grid>

        </StackPanel>
    </Border>
</Window>

