<Window x:Class="WPFHotel.AcercadeDiaglog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFHotel"
        mc:Ignorable="d"
        Title="Acerca de"
        Height="520" Width="440"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetName="Card"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4"/>
            <DoubleAnimation Storyboard.TargetName="Card"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="16" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Border x:Name="Card"
            Background="#1E1E2E"
            CornerRadius="16"
            BorderBrush="#2563A8"
            BorderThickness="1"
            Opacity="0">
        <Border.RenderTransform>
            <TranslateTransform Y="16"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="40"
                              ShadowDepth="0" Opacity="0.7"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Header azul     -->
                <RowDefinition Height="*"/>
                <!-- Contenido       -->
                <RowDefinition Height="Auto"/>
                <!-- Footer / botón  -->
            </Grid.RowDefinitions>

            <!-- ── Header ── -->
            <Border Grid.Row="0" Background="#2563A8"
                    CornerRadius="15,15,0,0" Padding="24,18">
                <StackPanel HorizontalAlignment="Center">

                    <!-- Logo casita -->
                    <Border Width="70" Height="70" CornerRadius="35"
                            Background="#1A3A6A"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,14">
                        <Border.Effect>
                            <DropShadowEffect Color="#60A5FA" BlurRadius="16"
                                              ShadowDepth="0" Opacity="0.6"/>
                        </Border.Effect>
                        <Viewbox Width="36" Height="36">
                            <Canvas Width="24" Height="24">
                                <Polygon Points="12,2 22,10 22,22 2,22 2,10"
                                         Stroke="#60A5FA" StrokeThickness="1.5"
                                         Fill="Transparent"/>
                                <Rectangle Canvas.Left="9" Canvas.Top="14"
                                           Width="6" Height="8"
                                           Fill="#60A5FA"/>
                            </Canvas>
                        </Viewbox>
                    </Border>

                    <TextBlock Text="Hotel Management"
                               FontFamily="Segoe UI" FontSize="20"
                               FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Sistema de Gestión Hotelera"
                               FontFamily="Segoe UI" FontSize="12"
                               Foreground="#93C5FD"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                    <TextBlock Text="Versión 1.0.0"
                               FontFamily="Segoe UI" FontSize="11"
                               Foreground="#6096C8"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- ── Contenido ── -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="28,20,28,4">
                <StackPanel>

                    <!-- Separador con texto -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,18">
                        <Border Height="1" Width="60" Background="#2A2A3E"
                                VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="DESARROLLADO POR"
                                   FontFamily="Segoe UI" FontSize="10"
                                   FontWeight="SemiBold" Foreground="#4B5563"
                                   VerticalAlignment="Center"/>
                        <Border Height="1" Width="60" Background="#2A2A3E"
                                VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>

                    <!-- Nombre del alumno -->
                    <TextBlock Text="Ángel de Jesús Polito Garuño"
                               FontFamily="Segoe UI" FontSize="16"
                               FontWeight="SemiBold" Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Ingeniería en Sistemas Computacionales"
                               FontFamily="Segoe UI" FontSize="12"
                               Foreground="#9CA3AF"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <!-- Institución -->
                    <Border Background="#252535" CornerRadius="10"
                            BorderBrush="#3B3B50" BorderThickness="1"
                            Padding="16,14" Margin="0,0,0,16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,8">
                                <!-- Ícono institución -->
                                <Border Width="28" Height="28" CornerRadius="6"
                                        Background="#1A3A6A" Margin="0,0,10,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="🎓" FontSize="14"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Institución educativa"
                                           FontFamily="Segoe UI" FontSize="11"
                                           FontWeight="SemiBold" Foreground="#6B7280"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Instituto Tecnológico de Minatitlán"
                                       FontFamily="Segoe UI" FontSize="14"
                                       FontWeight="SemiBold" Foreground="White"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,2"/>
                            <TextBlock Text="Tecnológico Nacional de México"
                                       FontFamily="Segoe UI" FontSize="11"
                                       Foreground="#9CA3AF"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Empresa productora -->
                    <Border Background="#252535" CornerRadius="10"
                            BorderBrush="#3B3B50" BorderThickness="1"
                            Padding="16,14" Margin="0,0,0,16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,8">
                                <Border Width="28" Height="28" CornerRadius="6"
                                        Background="#1A3A6A" Margin="0,0,10,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="🏢" FontSize="14"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Empresa productora"
                                           FontFamily="Segoe UI" FontSize="11"
                                           FontWeight="SemiBold" Foreground="#6B7280"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Politec"
                                       FontFamily="Segoe UI" FontSize="14"
                                       FontWeight="SemiBold" Foreground="White"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,2"/>
                            <TextBlock Text="Soluciones tecnológicas de vanguardia"
                                       FontFamily="Segoe UI" FontSize="11"
                                       Foreground="#9CA3AF"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Descripción del sistema -->
                    <Border Background="#1A1A2E" CornerRadius="10"
                            BorderBrush="#2A2A3E" BorderThickness="1"
                            Padding="16,12" Margin="0,0,0,8">
                        <TextBlock TextWrapping="Wrap"
                                   FontFamily="Segoe UI" FontSize="12"
                                   Foreground="#6B7280" LineHeight="20"
                                   TextAlignment="Center">
                            Sistema desarrollado como proyecto académico para la
                            administración integral de establecimientos hoteleros.
                            Gestión de habitaciones, huéspedes, reservaciones
                            y reportes en tiempo real.
                        </TextBlock>
                    </Border>

                    <!-- Tecnologías -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,8,0,4">
                        <Border Background="#1A3A6A" CornerRadius="12"
                                Padding="10,4" Margin="4,0">
                            <TextBlock Text="WPF / C#" FontFamily="Segoe UI"
                                       FontSize="11" Foreground="#60A5FA"/>
                        </Border>
                        <Border Background="#14532D" CornerRadius="12"
                                Padding="10,4" Margin="4,0">
                            <TextBlock Text="MySQL" FontFamily="Segoe UI"
                                       FontSize="11" Foreground="#4ADE80"/>
                        </Border>
                        <Border Background="#2D1A4A" CornerRadius="12"
                                Padding="10,4" Margin="4,0">
                            <TextBlock Text="LiveCharts2" FontFamily="Segoe UI"
                                       FontSize="11" Foreground="#A78BFA"/>
                        </Border>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- ── Footer ── -->
            <Border Grid.Row="2"
                    BorderBrush="#2A2A3E" BorderThickness="0,1,0,0"
                    Padding="24,14">
                <Grid>
                    <TextBlock Text="© 2026 Politec · Instituto Tecnológico de Minatitlán"
                               FontFamily="Segoe UI" FontSize="11"
                               Foreground="#4B5563"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"/>
                    <Button Content="Cerrar"
                            Click="BtnCerrar_Click"
                            HorizontalAlignment="Right"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="#2563A8"
                                        CornerRadius="8" Padding="18,7">
                                    <TextBlock Text="{TemplateBinding Content}"
                                               FontFamily="Segoe UI" FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="White"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background"
                                                Value="#1D4ED8"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="bg" Property="Background"
                                                Value="#1E40AF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
