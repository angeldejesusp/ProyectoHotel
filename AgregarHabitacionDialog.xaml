<Window x:Class="WPFHotel.AgregarHabitacionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFHotel"
        mc:Ignorable="d"
         Title="Nueva habitación"
        Height="352" Width="340"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="NoResize"
        Background="#2A2A2C">
    <Border Padding="28,24" CornerRadius="12">
        <StackPanel>
            <TextBlock Text="Nueva habitación" Foreground="White"
                       FontSize="16" FontWeight="SemiBold" Margin="0,0,0,20"/>

            <TextBlock Text="Número:" Foreground="#9CA3AF" FontSize="13" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtNumero" Background="#3A3A3C" Foreground="White"
                     BorderBrush="#555558" BorderThickness="1"
                     Padding="10,8" FontSize="14" Margin="0,0,0,14"/>

            <TextBlock Text="Costo por noche ($)" Foreground="#9CA3AF" FontSize="13" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtCosto" Background="#3A3A3C" Foreground="White"
                     BorderBrush="#555558" BorderThickness="1"
                     Padding="10,8" FontSize="14" Margin="0,0,0,14"/>

            <TextBlock Text="Tipo:" Foreground="#9CA3AF" FontSize="13" Margin="0,0,0,5"/>
            <ComboBox x:Name="CbbTipo" SelectedIndex="0"
                      Background="#3A3A3C" Foreground="Black"
                      BorderBrush="#555558" Padding="10,8"
                      FontSize="14" Margin="0,0,0,20">
                <ComboBoxItem Content="A — Estándar"/>
                <ComboBoxItem Content="B — Suite"/>
            </ComboBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar" Click="BtnCancelar_Click"
                        Background="#3A3A3C" Foreground="#ffff"
                        BorderThickness="0" Padding="14,8"
                        FontSize="13" Cursor="Hand" Margin="0,0,10,0"/>
                <Button Content="Agregar" Click="BtnConfirmar_Click"
                        Background="#2563A8" Foreground="White"
                        BorderThickness="0" Padding="14,8"
                        FontSize="13" FontWeight="SemiBold" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>