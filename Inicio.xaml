<Window x:Class="WPFHotel.Inicio"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        Height="600" Width="900"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <Window.Resources>

        <Style x:Key="TabBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#9CA3AF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabBtnActive" TargetType="Button" BasedOn="{StaticResource TabBtn}">
            <Setter Property="Foreground" Value="#60A5FA"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border Background="Transparent"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"
                                                  HorizontalAlignment="Center"/>
                            </Border>
                            <Border Height="2" VerticalAlignment="Bottom"
                                    Background="#60A5FA"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"      Value="#EFF6FF"/>
            <Setter Property="Foreground"      Value="#1D4ED8"/>
            <Setter Property="BorderBrush"     Value="#93C5FD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="14,7"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#DBEAFE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#BFDBFE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnSecondary" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background"  Value="#2D2D3F"/>
            <Setter Property="Foreground"  Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#4B5563"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#374151"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background"  Value="#FEE2E2"/>
            <Setter Property="Foreground"  Value="#B91C1C"/>
            <Setter Property="BorderBrush" Value="#FCA5A5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FECACA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TileDynamic" TargetType="Button">
            <Setter Property="Width"           Value="135"/>
            <Setter Property="Height"          Value="88"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="0,0,12,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="tileBorder"
                                Background="#DCFCE7"
                                BorderBrush="#86EFAC"
                                BorderThickness="1.5"
                                CornerRadius="12">
                            <StackPanel VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                <TextBlock x:Name="txtNum"
                                           Text="{Binding NumeroHabitacion}"
                                           FontSize="26" FontWeight="Bold"
                                           Foreground="#166534"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="txtEstado"
                                           Text="{Binding Estado}"
                                           FontSize="12" Foreground="#16A34A"
                                           HorizontalAlignment="Center"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding Disponible}" Value="False">
                                <Setter TargetName="tileBorder" Property="Background"  Value="#FEE2E2"/>
                                <Setter TargetName="tileBorder" Property="BorderBrush" Value="#FCA5A5"/>
                                <Setter TargetName="txtNum"     Property="Foreground"  Value="#991B1B"/>
                                <Setter TargetName="txtEstado"  Property="Foreground"  Value="#DC2626"/>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="tileBorder" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Columna encabezado -->
        <Style x:Key="ColHeader" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="#6B7280"/>
            <Setter Property="FontSize"          Value="11"/>
            <Setter Property="FontWeight"        Value="SemiBold"/>
            <Setter Property="FontFamily"        Value="Segoe UI"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <!-- Header  -->
            <RowDefinition Height="52"/>
            <!-- Tabs    -->
            <RowDefinition Height="1"/>
            <!-- Sep     -->
            <RowDefinition Height="*"/>
            <!-- Content -->
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="#2563A8">
            <Grid Margin="16,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox Width="22" Height="22" Margin="0,0,10,0">
                        <Canvas Width="24" Height="24">
                            <Polygon Points="12,2 22,10 22,22 2,22 2,10"
                                     Stroke="White" StrokeThickness="1.8"
                                     Fill="Transparent"/>
                            <Rectangle Canvas.Left="9" Canvas.Top="14"
                                       Width="6" Height="8" Fill="White"/>
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="Hotel Management"
                               FontSize="18" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ TABS + BOTONES ═══ -->
        <Border Grid.Row="1" Background="#252535">
            <DockPanel Margin="4,0" LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button Content="Inicio"    Style="{StaticResource TabBtnActive}"/>
                    <Button x:Name="BtnGestion" Content="Gestión"
                            Style="{StaticResource TabBtn}"
                            Click="BtnGestion_Click"/>
                    <Button Content="Reportes"  Style="{StaticResource TabBtn}" Click="BtnReportes_Click"/>
                    <Button x:Name="BtnAcercaDE" Content="Acerca de" Style="{StaticResource TabBtn}" Click="BtnAcercaDE_Click"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,8,0">
                    <Button x:Name="BtnAgregarHabitacion"
                            Content="+ Agregar habitación"
                            Style="{StaticResource BtnPrimary}"
                            Margin="0,0,8,0"
                            Click="BtnAgregarHabitacion_Click"
                            Visibility="Collapsed"/>
                   
                           
                    <Button x:Name="BtnCambiarContraseña"
                            Content="Cambiar contraseña"
                            Style="{StaticResource BtnSecondary}"
                            Margin="0,0,8,0"
                            Visibility="Collapsed" 
                            Click="BtnCambiarContraseña_Click"/>
                    <Button x:Name="BtnregistrarUsuario"
                            Content="Registrar Usuario"
                            Style="{StaticResource BtnSecondary}"
                            Margin="0,0,8,0"
                            Visibility="Collapsed"
                            Click="BtnregistrarUsuario_Click_1"/>
                    <Button Content="Salir"
                            Style="{StaticResource BtnDanger}"
                            Click="BtnSalir_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Separador -->
        <Border Grid.Row="2" Background="#3B3B50"/>

        <!-- ═══ CONTENIDO — TODO dentro del ScrollViewer ═══ -->
        <ScrollViewer Grid.Row="3"
                      VerticalScrollBarVisibility="Auto"
                      Background="#1E1E2E">
            <StackPanel Margin="24,16,24,24">

                <!-- Leyenda -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <TextBlock Text="Leyenda:" Foreground="#D1D5DB"
                               FontWeight="SemiBold" FontSize="14"
                               VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <Border Width="16" Height="16" CornerRadius="3"
                            Background="#DCFCE7" BorderBrush="#86EFAC"
                            BorderThickness="1.5" VerticalAlignment="Center"
                            Margin="0,0,6,0"/>
                    <TextBlock Text="Disponible" Foreground="#D1D5DB"
                               FontSize="14" VerticalAlignment="Center"
                               Margin="0,0,20,0"/>
                    <Border Width="16" Height="16" CornerRadius="3"
                            Background="#FEE2E2" BorderBrush="#FCA5A5"
                            BorderThickness="1.5" VerticalAlignment="Center"
                            Margin="0,0,6,0"/>
                    <TextBlock Text="Ocupada" Foreground="#D1D5DB"
                               FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Grupo Tipo A -->
                <StackPanel x:Name="PanelTipoA" Visibility="Collapsed" Margin="0,0,0,16">
                    <TextBlock Text="TIPO A — HABITACIÓN ESTÁNDAR"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#6B7280" Margin="0,0,0,10"/>
                    <ItemsControl x:Name="ListaTipoA">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource TileDynamic}"
                                        Click="TileHabitacion_Click"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Grupo Tipo B -->
                <StackPanel x:Name="PanelTipoB" Visibility="Collapsed" Margin="0,0,0,16">
                    <TextBlock Text="TIPO B — SUITE"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#6B7280" Margin="0,0,0,10"/>
                    <ItemsControl x:Name="ListaTipoB">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource TileDynamic}"
                                        Click="TileHabitacion_Click"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Sin habitaciones -->
                <Border x:Name="PanelVacio"
                        Background="#2A2A3E" BorderBrush="#3B3B50"
                        BorderThickness="1" CornerRadius="8"
                        Padding="20,30" Margin="0,0,0,16">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="No hay habitaciones registradas"
                                   Foreground="#6B7280" FontSize="15"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Presiona '+ Agregar habitación' para comenzar"
                                   Foreground="#4B5563" FontSize="13"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Nota -->

                <!-- ══════════════════════════════════════════ -->
                <!--  TABLA RESERVACIONES ACTIVAS              -->
                <!-- ══════════════════════════════════════════ -->
                <Border Background="#2A2A3E" BorderBrush="#3B3B50"
        BorderThickness="1" CornerRadius="10"
        Padding="0" Margin="0,0,0,8">
                    <StackPanel>

                        <!-- Cabecera -->
                        <Border Background="#252540" CornerRadius="10,10,0,0" Padding="16,12">
                            <Grid>
                                <TextBlock Text="Reservaciones activas"
                           FontFamily="Segoe UI" FontSize="14"
                           FontWeight="SemiBold" Foreground="White"/>
                                <TextBlock x:Name="TxtTotalReservaciones"
                           Text="0 activas"
                           FontFamily="Segoe UI" FontSize="12"
                           Foreground="#6B7280"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Encabezado columnas -->
                        <Border Background="#1E1E2E" Padding="16,8"
                BorderBrush="#3B3B50" BorderThickness="0,1,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="HAB."         Style="{StaticResource ColHeader}"/>
                                <TextBlock Grid.Column="1" Text="HUÉSPED"      Style="{StaticResource ColHeader}"/>
                                <TextBlock Grid.Column="2" Text="TIPO"         Style="{StaticResource ColHeader}"/>
                                <TextBlock Grid.Column="3" Text="FECHA SALIDA" Style="{StaticResource ColHeader}"/>
                                <TextBlock Grid.Column="4" Text="COSTO"        Style="{StaticResource ColHeader}"/>
                                <TextBlock Grid.Column="5" Text="ESTATUS"      Style="{StaticResource ColHeader}"/>
                                <TextBlock Grid.Column="6" Text="ACCIÓN"       Style="{StaticResource ColHeader}"
                           HorizontalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Filas dinámicas -->
                        <ItemsControl x:Name="ListaReservaciones">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#2A2A3E"
                            BorderThickness="0,0,0,1"
                            Padding="16,10">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#252540"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="{Binding Habitacion}"
                                       Foreground="#F0F0F0" FontSize="13"
                                       FontFamily="Segoe UI" VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="1" Text="{Binding NombreCompleto}"
                                       Foreground="#F0F0F0" FontSize="13"
                                       FontFamily="Segoe UI" VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="2" Text="{Binding TipoHabitacion}"
                                       Foreground="#9CA3AF" FontSize="12"
                                       FontFamily="Segoe UI" VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="3" Text="{Binding FechaSalidaStr}"
                                       Foreground="#9CA3AF" FontSize="12"
                                       FontFamily="Segoe UI" VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="4" Text="{Binding CostoStr}"
                                       Foreground="#4ADE80" FontSize="13"
                                       FontFamily="Segoe UI" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>

                                            <!-- Badge estatus -->
                                            <Border Grid.Column="5"
                                    CornerRadius="10" Padding="8,3"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#14532D"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Estatus}" Value="Vip">
                                                                <Setter Property="Background" Value="#1A3A6A"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Estatus}"
                                           FontSize="11" FontFamily="Segoe UI">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#4ADE80"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Estatus}" Value="Vip">
                                                                    <Setter Property="Foreground" Value="#60A5FA"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>

                                            <!-- Botón Checkout -->
                                            <Button Grid.Column="6"
                                    Content="Checkout"
                                    Tag="{Binding Habitacion}"
                                    Click="BtnCheckout_Click"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="bg"
                                                Background="#3B1414"
                                                CornerRadius="6"
                                                Padding="10,4">
                                                            <TextBlock Text="{TemplateBinding Content}"
                                                       Foreground="#F87171"
                                                       FontSize="12"
                                                       FontFamily="Segoe UI"
                                                       FontWeight="SemiBold"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="bg" Property="Background" Value="#4A1A1A"/>
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter TargetName="bg" Property="Background" Value="#5A2020"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>

                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Sin reservaciones -->
                        <Border x:Name="PanelSinReservaciones" Padding="16,20">
                            <TextBlock Text="No hay reservaciones activas en este momento"
                       FontFamily="Segoe UI" FontSize="12"
                       Foreground="#4B5563" HorizontalAlignment="Center"/>
                        </Border>

                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

    </Grid>
</Window>